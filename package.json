{
  "name": "vscode-snow-blue",
  "displayName": "Snow-Blue & Seasonal Themes",
  "description": "A calm, low-glare theme system for long coding sessions. Includes Snow Blue, Slate Amber Night, Christmas Night, and Christmas Day themes.",
  "version": "2.1.0",
  "publisher": "haileryle",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/haileryle/vscode-snow-blue"
  },
  "bugs": {
    "url": "https://github.com/haileryle/vscode-snow-blue/issues"
  },
  "homepage": "https://marketplace.visualstudio.com/items?itemName=haileryle.vscode-snow-blue",
  "keywords": [
    "theme",
    "color theme",
    "dark theme",
    "snow",
    "christmas",
    "amber",
    "slate"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Themes"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "snowthrone.switchTheme",
        "title": "Snow Throne: Switch Theme"
      },
      {
        "command": "snowthrone.openPreview",
        "title": "Snow Throne: Open Preview"
      }
    ],
    "themes": [
      {
        "label": "Snow Blue (Default)",
        "uiTheme": "vs-dark",
        "path": "./themes/snow-blue.json"
      },
      {
        "label": "Slate Amber Night (Premium Default)",
        "uiTheme": "vs-dark",
        "path": "./themes/slate-amber-night.json"
      },
      {
        "label": "Christmas Night",
        "uiTheme": "vs-dark",
        "path": "./themes/christmas-night.json"
      },
      {
        "label": "Christmas Day",
        "uiTheme": "vs",
        "path": "./themes/christmas-day.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node ./out/test/runTest.js",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@vscode/test-electron": "^2.3.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "puppeteer": "^24.41.0"
  }
}
